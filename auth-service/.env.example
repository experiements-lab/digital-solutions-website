# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.

# PostgreSQL
POSTGRES_USER=authsvc
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=auth

# Hydra DSN — uses the hydra schema inside the auth DB
HYDRA_DSN=postgres://authsvc:change_me_strong_password@postgres:5432/auth?sslmode=disable&search_path=hydra

# Kratos DSN — uses the kratos schema inside the auth DB
KRATOS_DSN=postgres://authsvc:change_me_strong_password@postgres:5432/auth?sslmode=disable&search_path=kratos

# Hydra secrets — generate with: openssl rand -hex 32
HYDRA_SYSTEM_SECRET=replace_with_64_hex_chars_openssl_rand_hex_32
HYDRA_COOKIE_SECRET=replace_with_64_hex_chars_openssl_rand_hex_32

# Kratos secrets — generate with: openssl rand -hex 32
KRATOS_COOKIE_SECRET=replace_with_64_hex_chars_openssl_rand_hex_32

# Public base URLs (update for production deployment)
PUBLIC_HYDRA_URL=http://localhost:4444
PUBLIC_KRATOS_URL=http://localhost:4433
PUBLIC_UI_URL=http://localhost:4455

# SMTP — dev uses Mailhog (no credentials needed)
# For production replace with: smtp://user:pass@smtp.sendgrid.net:587
SMTP_URI=smtp://mailhog:1025/?disable_starttls=true

# Consent app
HYDRA_ADMIN_URL=http://hydra:4445
